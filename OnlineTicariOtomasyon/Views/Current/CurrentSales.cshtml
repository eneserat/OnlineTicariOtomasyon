@model List<OnlineTicariOtomasyon.Models.Classes.CurrentSalesViewModel>
@{
    ViewBag.Title = "CurrentSales";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="card shadow-sm mt-4">
<div class="card-header bg-dark text-white">
    <i class="fas fa-shopping-cart me-2"></i> Cari Satış Geçmişi
</div>

<div class="card-body">

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning">
            Bu cariye ait satış bulunamadı.
        </div>
    }
    else
    {
        <table class="table table-hover table-striped text-center align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Satış ID</th>
                    <th>Ürün</th>
                    <th>Personel</th>
                    <th>Fiyat</th>
                    <th>Adet</th>
                    <th>Toplam</th>
                    <th>Tarih</th>
                    <th>Fatura</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var x in Model)
                {
                    <tr>
                        <td>@x.SalesID</td>

                        <td>
                            <span class="badge bg-primary px-3 py-2">
                                @x.Product
                            </span>
                        </td>

                        <td>@x.Employee</td>

                        <td>@x.Price ₺</td>

                        <td>@x.Quantity</td>

                        <td>
                            <span class="fw-bold text-success">
                                @x.Total ₺
                            </span>
                        </td>

                        <td>@x.Date.ToString("dd.MM.yyyy")</td>

                        <td>
                            <a href="/Current/CreateInvoice/@x.SalesID"
                               class="btn btn-success btn-sm">
                                <i class="fas fa-file-invoice"></i> Oluştur
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="mt-3">
        <a href="/Current/Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Geri Dön
        </a>
    </div>

</div>
</div>