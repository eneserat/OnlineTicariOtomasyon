@model List<OnlineTicariOtomasyon.Models.Classes.Current>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<br />

<div class="card shadow-sm">


    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">

        <div>
            <i class="fas fa-users me-2"></i>
            Cari Listesi
        </div>

        <a href="/Current/CurrentAdd" class="btn btn-success btn-sm d-flex align-items-center gap-2">
            <i class="fas fa-user-plus"></i>
            Yeni Cari
        </a>

    </div>

    <div class="card-body">


        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                <i class="fas fa-check-circle me-1"></i>
                @TempData["Success"]
            </div>
        }


        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                @TempData["Error"]
            </div>
        }


        <table class="table table-hover table-bordered align-middle">

            <thead class="table-dark">
                <tr>
                    <th><i class="fas fa-hashtag"></i> ID</th>

                    <th><i class="fas fa-user"></i> Ad</th>
                    <th><i class="fas fa-user-tag"></i> Soyad</th>
                    <th><i class="fas fa-city"></i> Şehir</th>
                    <th><i class="fas fa-envelope"></i> Mail</th>
                    <th><i class="fas fa-cogs"></i> İşlemler</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.CurrentID</td>
                        <td>@item.CurrentName</td>
                        <td>@item.CurrentSurname</td>
                        <td>@item.CurrentCity</td>
                        <td>@item.CurrentMail</td>


                        <td class="text-center">

                            <a href="/Current/CurrentEdit/@item.CurrentID"
                               class="btn btn-primary btn-sm me-1">
                                <i class="fas fa-pen"></i>
                            </a>

                            <a href="/Current/CurrentDelete/@item.CurrentID"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Bu cariyi silmek istiyor musun?');">
                                <i class="fas fa-trash"></i>
                            </a>

                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>
</div>

<link href="https://use.fontawesome.com/releases/v6.3.0/css/all.css" rel="stylesheet">