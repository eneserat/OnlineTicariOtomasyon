@model OnlineTicariOtomasyon.Models.Classes.Invoice
@{
    ViewBag.Title = "InvoiceAdd";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<br />

<div class="card shadow-sm col-12">


    <div class="card-header bg-dark text-white">
        <i class="fas fa-file-circle-plus me-2"></i>
        Yeni Fatura Ekle
    </div>

    <div class="card-body">

        <form method="post">

            <div class="mb-3">
                <label class="form-label">
                    <i class="fas fa-barcode me-1"></i> Seri No
                </label>
                @Html.TextBoxFor(x => x.InvoiceSerialNumber, new { @class = "form-control", placeholder = "Seri No giriniz..." })
            </div>

            <div class="mb-3">
                <label class="form-label">
                    <i class="fas fa-hashtag me-1"></i> Sıra No
                </label>
                @Html.TextBoxFor(x => x.InvoiceSiraNumber, new { @class = "form-control", placeholder = "Sıra No giriniz..." })
            </div>

            <div class="mb-3">
                <label class="form-label">
                    <i class="fas fa-building-columns me-1"></i> Vergi Dairesi
                </label>
                @Html.TextBoxFor(x => x.InvoiceTaxOffice, new { @class = "form-control", placeholder = "Vergi dairesi..." })
            </div>

            <div class="mb-3">
                <label class="form-label">
                    <i class="fas fa-user-check me-1"></i> Teslim Eden
                </label>
                @Html.TextBoxFor(x => x.InvoiceSubmitter, new { @class = "form-control", placeholder = "Teslim eden kişi..." })
            </div>

            <div class="mb-3">
                <label class="form-label">
                    <i class="fas fa-user me-1"></i> Teslim Alan
                </label>
                @Html.TextBoxFor(x => x.InvoiceReceiver, new { @class = "form-control", placeholder = "Teslim alan kişi..." })
            </div>

           
            <div class="d-flex justify-content-between mt-4">

                <a href="/Invoice/Index" class="btn btn-secondary d-flex align-items-center gap-2">
                    <i class="fas fa-arrow-left"></i>
                    Geri
                </a>

                <button class="btn btn-success d-flex align-items-center gap-2">
                    <i class="fas fa-save"></i>
                    Kaydet
                </button>

            </div>

        </form>

    </div>
</div>


<link href="https://use.fontawesome.com/releases/v6.3.0/css/all.css" rel="stylesheet">