@model List<OnlineTicariOtomasyon.Models.Classes.Invoice>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<br />

<div class="card shadow-sm">

  
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <div>
            <i class="fas fa-file-invoice me-2"></i>
            Fatura Listesi
        </div>

       
        <a href="/Invoice/InvoiceAdd" class="btn btn-success btn-sm">
            <i class="fas fa-plus"></i> Yeni Fatura
        </a>
    </div>

    <div class="card-body">

      
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                <i class="fas fa-check-circle me-1"></i>
                @TempData["Success"]
            </div>
        }

        @if (Model == null || !Model.Any())
        {
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle me-1"></i>
                Kayıt bulunamadı
            </div>
        }
        else
        {
            <table class="table table-hover table-bordered align-middle">

                <thead class="table-dark">
                    <tr>
                        <th><i class="fas fa-hashtag"></i> ID</th>
                        <th><i class="fas fa-barcode"></i> Seri No</th>
                        <th><i class="fas fa-sort-numeric-up"></i> Sıra No</th>
                        <th><i class="fas fa-building"></i> Vergi Dairesi</th>
                        <th><i class="fas fa-calendar"></i> Tarih</th>
                        <th><i class="fas fa-user"></i> Teslim Eden</th>
                        <th><i class="fas fa-user-check"></i> Teslim Alan</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var k in Model)
                    {
                        <tr>
                            <td>@k.InvoiceID</td>
                            <td>@k.InvoiceSerialNumber</td>
                            <td>@k.InvoiceSiraNumber</td>
                            <td>@k.InvoiceTaxOffice</td>
                            <td>@k.InvoiceDate</td>
                            <td>@k.InvoiceSubmitter</td>
                            <td>@k.InvoiceReceiver</td>
                        </tr>
                    }
                </tbody>

            </table>
        }

    </div>
</div>


<link href="https://use.fontawesome.com/releases/v6.3.0/css/all.css" rel="stylesheet">