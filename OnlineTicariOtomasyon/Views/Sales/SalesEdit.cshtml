@model List<OnlineTicariOtomasyon.Models.Classes.SalesTransaction>
@{
    ViewBag.Title = "SalesEdit";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Satış Hareketleri Düzenleme Paneli</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Ürün</th>
            <th>Cari</th>
            <th>Personel</th>
            <th>Adet</th>
            <th>Fiyat</th>
            <th>Toplam</th>
            <th>İşlemler</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var x in Model)
        {
            <tr>

               
                <form method="post" action="/Sales/SalesEdit">

                <td>
                    @x.SalesTransactionsID
                    <input type="hidden" name="SalesTransactionsID" value="@x.SalesTransactionsID" />
                </td>

                <td>
                    <input type="number" name="ProductID" value="@x.ProductID" class="form-control" />
                </td>

                <td>
                    <input type="number" name="CurrentID" value="@x.CurrentID" class="form-control" />
                </td>

                <td>
                    <input type="number" name="EmployeeID" value="@x.EmployeeID" class="form-control" />
                </td>

                <td>
                    <input type="number" name="SalesTransactionsAmount" value="@x.SalesTransactionsTotalAmount" class="form-control" />
                </td>

                <td>
                    @x.SalesTransactionsPrice
                </td>

                <td>
                    @x.SalesTransactionsTotalAmount
                </td>

                <td>

                    
                    <button type="submit" class="btn btn-success btn-sm">
                        Güncelle
                    </button>

                   
                    <a href="/Sales/SalesDelete/@x.SalesTransactionsID"
                       class="btn btn-danger btn-sm"
                       onclick="return confirm('Gerçekten silmek istiyor musun?');">
                        Sil
                    </a>

                </td>

                </form>
              

            </tr>
        }
    </tbody>
</table>


