@model OnlineTicariOtomasyon.Models.Classes.SalesTransaction
@{
    ViewBag.Title = "SalesAdd";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="container mt-4">
    <h3 class="mb-3"><i class="fas fa-cart-plus me-2"></i> Satış Ekle</h3>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @using (Html.BeginForm("SalesAdd", "SalesTransaction", FormMethod.Post))
    {
        <div class="mb-3">
            @Html.LabelFor(m => m.ProductID, "Ürün Seçiniz", new { @class = "form-label" })
            @Html.DropDownListFor(m => m.ProductID, (SelectList)ViewBag.Products, "Ürün Seçiniz", new { @class = "form-select" })
        </div>

        <div class="mb-3">
            @Html.LabelFor(m => m.CurrentID, "Cari Seçiniz", new { @class = "form-label" })
            @Html.DropDownListFor(m => m.CurrentID, (SelectList)ViewBag.Currents, "Cari Seçiniz", new { @class = "form-select" })
        </div>

        <div class="mb-3">
            @Html.LabelFor(m => m.EmployeeID, "Personel Seçiniz", new { @class = "form-label" })
            @Html.DropDownListFor(m => m.EmployeeID, (SelectList)ViewBag.Employees, "Personel Seçiniz", new { @class = "form-select" })
        </div>

        <div class="mb-3">
            @Html.LabelFor(m => m.SalesTransactionsTotalAmount, "Adet", new { @class = "form-label" })
            @Html.TextBoxFor(m => m.SalesTransactionsTotalAmount, new { @class = "form-control", placeholder = "Kaç adet satıldı?" })
        </div>

        <button type="submit" class="btn btn-success">
            <i class="fas fa-check me-1"></i> Satışı Kaydet
        </button>
    }
</div>