@model OnlineTicariOtomasyon.Models.Classes.Product
@{
    ViewBag.Title = "ProductAdd";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
        <i class="fas fa-check-circle me-2"></i>
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<br />
<div class="card shadow-sm mt-4 col-md-10 offset-md-1">

    <div class="card-header bg-dark text-white">
        <i class="fas fa-box-open me-2"></i> Ürün Ekleme Sayfası
    </div>

    <div class="card-body">
        <form class="form-group" method="post" enctype="multipart/form-data">

            <label class="form-label"><i class="fas fa-box me-1"></i> Ürün Adı</label>
            @Html.TextBoxFor(x => x.ProductName, new { @class = "form-control", placeholder = "Ürün Adını Giriniz..." })

            <label class="form-label mt-2"><i class="fas fa-tag me-1"></i> Ürün Marka</label>
            @Html.TextBoxFor(x => x.ProductBrand, new { @class = "form-control", placeholder = "Ürün Markasını Giriniz..." })

            <label class="form-label mt-2"><i class="fas fa-layer-group me-1"></i> Stok</label>
            @Html.TextBoxFor(x => x.ProductStock, new { @class = "form-control", placeholder = "Stok Adedi", type = "number" })

            <label class="form-label mt-2"><i class="fas fa-dollar-sign me-1"></i> Alış Fiyat</label>
            @Html.TextBoxFor(x => x.PurchasePrice, new { @class = "form-control", placeholder = "Alış Fiyat", type = "number", step = "0.01" })

            <label class="form-label mt-2"><i class="fas fa-dollar-sign me-1"></i> Satış Fiyat</label>
            @Html.TextBoxFor(x => x.SellingPrice, new { @class = "form-control", placeholder = "Satış Fiyat", type = "number", step = "0.01" })

            <label class="form-label mt-2"><i class="fas fa-image me-1"></i> Ürün Görsel</label>
            @Html.TextBoxFor(x => x.ProductImage, new { @class = "form-control", placeholder = "Görsel URL" })

            <label class="form-label mt-2"><i class="fas fa-tags me-1"></i> Kategori</label>
            @Html.DropDownListFor(x => x.CategoryID, (SelectList)ViewBag.Categories, "--Kategori Seç--", new { @class = "form-select" })

            <div class="d-flex justify-content-between mt-4">
                <a href="/Product/Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Geri Dön
                </a>
                <button class="btn btn-success">
                    <i class="fas fa-save"></i> Kaydet
                </button>
            </div>
        </form>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>

