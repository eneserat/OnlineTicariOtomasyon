@model List<OnlineTicariOtomasyon.Models.Classes.Admin>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}



<div class="container mt-4">

    <div class="d-flex justify-content-between mb-3">
        <h3><i class="fas fa-user-shield me-2"></i> Adminler</h3>
        <a href="@Url.Action("AdminAdd", "Admin")" class="btn btn-success">
            <i class="fas fa-plus me-1"></i> Yeni Admin
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <table class="table table-bordered table-hover table-striped shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Kullanıcı Adı</th>
                <th>Şifre</th>
                <th>Yetki / Rol</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var admin = Model[i];
                <tr>
                    <td>@(i + 1)</td>
                    <td>@admin.UserName</td>
                    <td>@admin.Password</td>
                    <td>@admin.Authority</td>
                    <td>
                        <a href="@Url.Action("AdminEdit", "Admin", new { id = admin.AdminID })"
                           class="btn btn-primary btn-sm me-1">
                            <i class="fas fa-edit me-1"></i> Düzenle
                        </a>

                        @using (Html.BeginForm("AdminDelete", "Admin", FormMethod.Post,
                               new { onsubmit = "return confirm('Silmek istediğinize emin misiniz?');", style = "display:inline;" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@admin.AdminID" />
                            <button type="submit" class="btn btn-danger btn-sm">
                                <i class="fas fa-trash me-1"></i> Sil
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>

