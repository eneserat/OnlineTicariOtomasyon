@model OnlineTicariOtomasyon.Models.Classes.Employee
@{
    ViewBag.Title = "EmployeeAssignDepartment";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <h3>Departman Atama - @Model.EmployeeName @Model.EmployeeSurname</h3>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <form asp-action="EmployeeAssignDepartment" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="EmployeeID" value="@Model.EmployeeID" />

        <div class="mb-3">
            <label class="form-label">Ad</label>
            <input type="text" class="form-control" value="@Model.EmployeeName" disabled />
        </div>

        <div class="mb-3">
            <label class="form-label">Soyad</label>
            <input type="text" class="form-control" value="@Model.EmployeeSurname" disabled />
        </div>

        <div class="mb-3">
            <label class="form-label">Departman</label>
            @Html.DropDownList("DepartmentID", (SelectList)ViewBag.Departments, "Departman Seç", new { @class = "form-select" })
        </div>

        <button type="submit" class="btn btn-success">
            <i class="fas fa-check me-1"></i> Atamayı Kaydet
        </button>
        <a href="@Url.Action("EmployeAssignDepartment","Employee")" class="btn btn-secondary ms-2">Geri</a>
    </form>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>