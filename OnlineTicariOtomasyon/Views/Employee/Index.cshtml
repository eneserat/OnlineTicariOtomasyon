@model List<OnlineTicariOtomasyon.Models.Classes.Employee>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between mb-3">
        <h3><i class="fas fa-users me-2"></i> Personeller</h3>
        <a href="@Url.Action("EmployeeAdd", "Employee")" class="btn btn-success">
            <i class="fas fa-user-plus me-1"></i> Yeni Personel Ekle
        </a>
    </div>

    <table class="table table-bordered table-hover table-striped shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Görsel</th>
                <th>Ad</th>
                <th>Soyad</th>
                <th>Departman</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count(); i++)
            {
                var p = Model.ElementAt(i);
                <tr>
                    <td>@(i + 1)</td>

                    <td>
                        @if (!string.IsNullOrEmpty(p.EmployeeImage))
                        {
                            <img src="@Url.Content(p.EmployeeImage)" style="width:50px;height:50px;object-fit:cover;border-radius:5px;" />
                        }
                        else
                        {
                            <i class="fas fa-user fa-2x text-secondary"></i>
                        }
                    </td>

                    <td>@p.EmployeeName</td>
                    <td>@p.EmployeeSurname</td>
                    <td>@(p.Department != null ? p.Department.DepartmentName : "-")</td>

                    <td>
                        <a href="@Url.Action("EmployeeEdit","Employee", new { id = p.EmployeeID })"
                           class="btn btn-primary btn-sm me-1">
                            <i class="fas fa-edit me-1"></i> Düzenle
                        </a>

                        @using (Html.BeginForm("EmployeeDelete", "Employee", FormMethod.Post,
                               new { onsubmit = "return confirm('Silmek istediğinize emin misiniz?');", style = "display:inline;" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@p.EmployeeID" />
                            <button type="submit" class="btn btn-danger btn-sm">
                                <i class="fas fa-trash me-1"></i> Sil
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
