@model OnlineTicariOtomasyon.Models.Classes.Employee
@{
    ViewBag.Title = "EmployeeEdit";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}



<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4><i class="fas fa-user-edit me-2"></i> Personel Düzenle</h4>
        </div>
        <div class="card-body">

            @if (ViewBag.Success != null)
            {
                <div class="alert alert-success alert-dismissible fade show mt-3">
                    <i class="fas fa-check-circle me-2"></i>@ViewBag.Success
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mt-3">
                    <i class="fas fa-exclamation-triangle me-2"></i>@ViewBag.Error
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @using (Html.BeginForm("EmployeeEdit", "Employee", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.EmployeeID)

                <div class="mb-3">
                    <label class="form-label">Personel Adı</label>
                    @Html.TextBoxFor(m => m.EmployeeName, new { @class = "form-control" })
                </div>

                <div class="mb-3">
                    <label class="form-label">Personel Soyadı</label>
                    @Html.TextBoxFor(m => m.EmployeeSurname, new { @class = "form-control" })
                </div>

                <div class="mb-3">
                    <label class="form-label">Departman</label>
                    @Html.DropDownList("DepartmentID", (SelectList)ViewBag.Departments, "Seçiniz", new { @class = "form-select" })
                </div>

                <div class="mb-3">
                    <label class="form-label">Görsel</label>
                    @if (!string.IsNullOrEmpty(Model.EmployeeImage))
                    {
                        <div class="mb-2">
                            <img src="@Url.Content(Model.EmployeeImage)" style="width:80px;height:80px;object-fit:cover;border-radius:5px;" />
                        </div>
                    }
                    <input type="file" name="EmployeeImage" class="form-control" accept="image/*" />
                </div>

                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1"></i> Güncelle
                </button>
                <a href="@Url.Action("Index","Employee")" class="btn btn-secondary ms-2">
                    <i class="fas fa-arrow-left me-1"></i> Geri
                </a>
            }
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>