
@{
    ViewBag.Title = "Index";
    Layout = null;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>

<style>
    body {
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        height: 100vh;
    }

    .login-card {
        background: #fff;
        border-radius: 12px;
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        width: 400px;
    }

        .login-card h3 {
            font-weight: 600;
            color: #1e3c72;
        }

    .form-label {
        font-weight: 500;
        color: #333;
    }

    .btn-login {
        background: #1e3c72;
        border: none;
    }

        .btn-login:hover {
            background: #2a5298;
        }

    .alert {
        font-size: 0.9rem;
    }
</style>

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="login-card">
        <div class="text-center mb-4">
            <i class="fas fa-user-shield fa-3x text-primary"></i>
            <h3 class="mt-2">Admin Girişi</h3>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        @using (Html.BeginForm("Login", "Account", FormMethod.Post))
        {
            <div class="mb-3">
                @Html.Label("Kullanıcı Adı", htmlAttributes: new { @class = "form-label" })
                @Html.TextBox("Username", null, new { @class = "form-control", placeholder = "Kullanıcı adı giriniz" })
            </div>

            <div class="mb-3">
                @Html.Label("Şifre", htmlAttributes: new { @class = "form-label" })
                @Html.Password("Password", null, new { @class = "form-control", placeholder = "Şifre giriniz" })
            </div>

            <div class="mb-4">
                @Html.Label("Yetki", htmlAttributes: new { @class = "form-label" })
                @Html.DropDownList("Authority", new SelectList(new[] { "Müdür", "Personel", "Yönetici" }), "Yetki Seçiniz", new { @class = "form-select" })
            </div>

            <button type="submit" class="btn btn-login w-100 text-white">
                <i class="fas fa-sign-in-alt me-1"></i> Giriş Yap
            </button>
        }
    </div>
</div>