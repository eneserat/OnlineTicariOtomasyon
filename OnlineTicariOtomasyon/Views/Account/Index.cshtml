
@{
    ViewBag.Title = "Index";
    Layout = null;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>

<style>
    body {
        background: linear-gradient(135deg, #667eea, #764ba2);
        height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .card {
        border-radius: 15px;
    }

    .input-group-text {
        background-color: #764ba2;
        color: #fff;
        border: none;
        border-radius: 0.375rem 0 0 0.375rem;
    }

    .form-control:focus {
        box-shadow: none;
        border-color: #764ba2;
    }

    .btn-primary {
        background-color: #764ba2;
        border: none;
        transition: all 0.3s ease;
    }

        .btn-primary:hover {
            background-color: #667eea;
        }
</style>

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg p-4" style="width: 400px;">
        <h3 class="text-center mb-4 text-white"><i class="fas fa-user-shield me-2"></i> Admin Girişi</h3>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger d-flex align-items-center">
                <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
            </div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success d-flex align-items-center">
                <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            </div>
        }

        @using (Html.BeginForm("Login", "Account", FormMethod.Post))
        {
            <div class="mb-3 input-group">
                <span class="input-group-text"><i class="fas fa-user"></i></span>
                @Html.TextBox("Username", null, new { @class = "form-control", placeholder = "Kullanıcı adı giriniz" })
            </div>

            <div class="mb-3 input-group">
                <span class="input-group-text"><i class="fas fa-lock"></i></span>
                @Html.Password("Password", null, new { @class = "form-control", placeholder = "Şifre giriniz" })
            </div>

            <div class="mb-3 input-group">
                <span class="input-group-text"><i class="fas fa-shield-alt"></i></span>
                @Html.DropDownList("Authority", new SelectList(new[] { "Müdür", "Personel", "Yönetici" }), "Yetki Seçiniz", new { @class = "form-select" })
            </div>

            <button type="submit" class="btn btn-primary w-100 mt-3">
                <i class="fas fa-sign-in-alt me-2"></i> Giriş Yap
            </button>
        }
    </div>
</div>