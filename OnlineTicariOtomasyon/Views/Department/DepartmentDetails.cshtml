@model OnlineTicariOtomasyon.Models.Classes.DepartmentDetailsVM
@{
    ViewBag.Title = "DepartmentDetails";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h3>@Model.DepartmentName - Personel Detayları</h3>
<p>Toplam Personel: @Model.Employees.Count</p>

<table class="table table-striped">
    <thead>
        <tr><th>#</th><th>Ad</th><th>Soyad</th></tr>
    </thead>
    <tbody>
        @for (int i = 0; i < Model.Employees.Count; i++)
        {
            <tr>
                <td>@(i+1)</td>
                <td>@Model.Employees[i].Name</td>
                <td>@Model.Employees[i].Surname</td>
            </tr>
        }
    </tbody>
</table>
