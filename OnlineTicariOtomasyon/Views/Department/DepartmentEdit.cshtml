@model OnlineTicariOtomasyon.Models.Classes.Department
@{
    ViewBag.Title = "DepartmentEdit";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}



<h3><i class="fas fa-building me-2"></i> Departman Düzenle</h3>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-3">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mt-3">
        <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@using (Html.BeginForm("DepartmentEdit", "Department", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(x => x.DepartmentID)

    <div class="mb-3">
        <label class="form-label">Departman Adı</label>
        @Html.TextBoxFor(x => x.DepartmentName, new { @class = "form-control" })
    </div>

    <div class="mb-3">
        <label class="form-label">Görsel URL</label>
        @Html.TextBoxFor(x => x.DepartmentImage, new { @class = "form-control" })
    </div>

    <button type="submit" class="btn btn-primary">
        <i class="fas fa-save me-1"></i> Güncelle
    </button>
    <a href="@Url.Action("Index","Department")" class="btn btn-secondary ms-2">İptal</a>
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>