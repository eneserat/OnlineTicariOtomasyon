@model IEnumerable<OnlineTicariOtomasyon.Models.Classes.Department>
    @{
        ViewBag.Title = "DepartmentEdit";
        Layout = "~/Views/Shared/_AdminLayout.cshtml";
    }

    <br />

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mt-3">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between mb-3">
        <h3><i class="fas fa-building me-2"></i> Departmanlar</h3>
        <a href="/Department/DepartmentAdd" class="btn btn-success">
            <i class="fas fa-plus me-1"></i> Yeni Departman
        </a>
    </div>

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Departman Adı</th>
                <th>Görsel</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model)
            {
                <tr>
                    <td>@d.DepartmentID</td>
                    <td>@d.DepartmentName</td>
                    <td>
                        @if (!string.IsNullOrEmpty(d.DepartmentImage))
                        {
                            <img src="@d.DepartmentImage" style="width:50px;height:50px;object-fit:cover;border-radius:5px;" />
                        }
                        else
                        {
                            <i class="fas fa-building fa-2x text-secondary"></i>
                        }
                    </td>
                    <td>

                        <a href="@Url.Action("DepartmentEdit", "Department", new { id = d.DepartmentID })"
                           class="btn btn-primary btn-sm me-1"
                           style="display:inline-block !important; visibility:visible !important;">
                            <i class="fas fa-edit me-1"></i> Güncelle
                        </a>

                        @using (Html.BeginForm("DepartmentDelete", "Department", FormMethod.Post,
                        new { onsubmit = "return confirm('Silmek istediğinize emin misiniz?');", style="display:inline;" }))
                        {
                        <input type="hidden" name="id" value="@d.DepartmentID" />
                        <button type="submit" class="btn btn-danger btn-sm">
                            <i class="fas fa-trash me-1"></i> Sil
                        </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>

