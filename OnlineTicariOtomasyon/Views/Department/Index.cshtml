@using OnlineTicariOtomasyon.Models.Classes
@model List<Department>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<table class="table table-bordered table-hover mt-3">
    <thead class="table-dark">
        <tr>
            <th><i class="fas fa-id-badge me-1"></i> Departman ID</th>
            <th><i class="fas fa-building me-1"></i> Departman Adı</th>
            <th><i class="fas fa-image me-1"></i> Departman Görsel</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var d in Model)
        {
            <tr>
                <td>@d.DepartmentID</td>
                <td>@d.DepartmentName</td>
                <td>
                    @if (!string.IsNullOrEmpty(d.DepartmentImage))
                    {
                        <img src="@d.DepartmentImage" alt="@d.DepartmentName" style="width:50px; height:50px; object-fit:cover; border-radius:5px;" />
                    }
                    else
                    {
                        <i class="fas fa-building fa-2x text-secondary"></i>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>

